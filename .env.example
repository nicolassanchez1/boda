# --- Database (Neon Postgres) ---
# Pooled connection — used by the app at runtime (Neon: hostname ends in -pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-POOLER.neon.tech/DBNAME?sslmode=require"
# Direct (unpooled) connection — used by `prisma migrate` only (Neon: hostname without -pooler)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# --- Admin auth ---
# Password required to enter /admin
ADMIN_PASSWORD="change-me-please"
# 32+ random chars; used to sign the admin session cookie. Generate with: openssl rand -base64 48
AUTH_SECRET="please-replace-with-a-long-random-string"

# --- RSVP deadline ---
# ISO datetime. After this moment, guest responses are read-only.
RSVP_DEADLINE="2026-02-14T18:00:00-05:00"

# --- Public wedding info (placeholder values — replace for your event) ---
NEXT_PUBLIC_WEDDING_DATE="Sábado 14 de febrero de 2026"
NEXT_PUBLIC_WEDDING_TIME="5:00 p.m."
NEXT_PUBLIC_VENUE="Hacienda San José, Bogotá"

# --- App ---
# Used to build absolute invitation links in admin messages.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
